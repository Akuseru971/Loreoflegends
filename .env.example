NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=lol-video-assets

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional image search provider. Without these, the app uses deterministic demo candidates.
BING_IMAGE_SEARCH_KEY=
BING_IMAGE_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/images/search

# FFmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
WORKDIR=/tmp/loreoflegends

# Worker
WORKER_POLL_INTERVAL_MS=5000
